+// ── توليد 50 تدبيراً محلياً مع الحفاظ على البيانات الأساسية ──
+function _expand50(pf){
+  var base=(_DEMO[pf]||[]).map(function(x){return Object.assign({},x);});
+  var countries=['United States','European Union','China','India','Brazil','Canada','Japan','Korea, Rep.','United Kingdom','Australia','Turkey','South Africa','Indonesia','Malaysia','Singapore'];
+  var products=[
+    ['760110','Aluminium, unwrought','الألومنيوم الخام'],
+    ['310210','Ammonium nitrate','نترات الأمونيوم'],
+    ['270900','Crude petroleum','النفط الخام'],
+    ['390110','Polyethylene primary','البولي إيثيلين'],
+    ['720241','Ferrochromium','الفيروكروم'],
+    ['080410','Dates, fresh or dried','التمور الطازجة أو المجففة'],
+    ['290213','Toluene','التولوين'],
+    ['150110','Palm oil, crude','زيت النخيل الخام'],
+    ['720110','Non-alloy pig iron','حديد خام غير مخلوط'],
+    ['020110','Bovine meat, fresh','لحوم الأبقار الطازجة']
+  ];
+  var types=['SPS','TBT','ADP','CV','SG','QR'];
+  var phases=['In Force','Initiation','Review','Draft','Adopted'];
+  var out=base.slice(0,50);
+  var i=0;
+  while(out.length<50){
+    var pr=products[i%products.length], tp=types[i%types.length], c=countries[i%countries.length];
+    var sa=['ADP','CV','SG','TBT','SPS'].indexOf(tp)>=0 && (i%3!==1);
+    var code=(pf==='un'?'UN-NTM-':'WTO-NTM-')+String(out.length+1).padStart(3,'0');
+    out.push({
+      r:c,
+      p:sa?'Saudi Arabia':'World',
+      hs:pr[0],
+      prod:pr[1],
+      yr:2024-(i%3),
+      code:code,
+      tp:tp,
+      en:(pf==='un'?'UNCTAD TRAINS':'WTO I-TIP')+' measure on '+pr[1]+' applied by '+c,
+      ar:'تدبير غير جمركي على '+pr[2]+' مطبق من '+c+(sa?' — قد يؤثر على صادرات أو واردات المملكة':''),
+      legal:(tp==='SPS'?'SPS Agreement':tp==='TBT'?'TBT Agreement':tp==='ADP'?'Anti-Dumping Agreement':tp==='CV'?'SCM Agreement':tp==='SG'?'Safeguards Agreement':'GATT 1994'),
+      ph:phases[i%phases.length],
+      sa:sa
+    });
+    i++;
+  }
+  return out.slice(0,50);
+}
